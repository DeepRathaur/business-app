"use client";
import { BannerModel } from "@/shared/models";
import { useState, useEffect } from "react";

export default function BannerSlider({ slides, onClick }: { slides: BannerModel[], onClick: (actionType: BannerModel) => void; }) {
  const [currentIndex, setCurrentIndex] = useState(0);
  const goToSlide = (index: any) => setCurrentIndex(index);

  useEffect(() => {
    const interval = setInterval(() => {
      setCurrentIndex((prev) => (prev + 1) % slides.length);
    }, 5000);
    return () => clearInterval(interval);
  }, []);

  return (

    <section className="mt-3 mx-2.5">
      <div className="overflow-hidden rounded-xl bg-white shadow-sm">
      <div
        className="flex transition-transform duration-500 ease-in-out"
        style={{ transform: `translateX(-${currentIndex * 100}%)` }}
      >
        {slides.map((slide, i) => (
          <div
            key={i}
            className="min-w-full box-border"
            aria-hidden={i === currentIndex ? "false" : "true"}
          >
            <img
              src={slide.imageUri}
              alt={`Slide ${i + 1}`}
              className="h-[155px] w-full object-cover block cursor-pointer"
              onClick={() => onClick(slide)}
            />
          </div>
        ))}
      </div>
      </div>
    </section>
  );
}


"use client";

import Image from "next/image";
import { accountService } from "@/core/service/accountService";
import { OptionsModel } from "@/shared/models/options.model";
import { useEffect, useState } from "react";
import { useInterModuleNavigationService, useServiceTypes } from "@/hooks";
import { ServiceCategoryEnum } from "@/shared/enum/service-category.enum";
import { mapServiceTypes } from "@/utills/serviceMapper";
import { motion, AnimatePresence, PanInfo } from "framer-motion";
import { getServiceCategoryTabs } from "@/utills";
import { AppConfiguration } from "@/shared/models";
import { useRouter } from "next/navigation";
import { Navigation } from "@/core/constant";

type ServiceProps = {
  configuration: AppConfiguration;
};

export default function ServicePage({ configuration }: ServiceProps) {
  const router = useRouter();
  const [serviceTypesArr, setServiceTypes] = useState<OptionsModel[]>([]);
  const [currentCategory, setCurrentCategory] =
    useState<ServiceCategoryEnum>();

  const role = accountService.getEnterPriseRole();
  const productType = configuration?.ProductType ?? [];
  const { toService } = useInterModuleNavigationService();

  const {
    getAllServiceTypes,
    getServiceTypeListByCategory,
    serviceTypeList,
    currentServiceType,
    setCurrentServiceType,
  } = useServiceTypes({ productType, currentCategory });

  useEffect(() => {
    const types = getAllServiceTypes();
    setServiceTypes(types);
  }, []);

  const tabServiceCategory = getServiceCategoryTabs(
    configuration,
    role,
    serviceTypesArr
  );

  const services = mapServiceTypes(tabServiceCategory);

  const pageSize = 4;
  const totalPages = Math.ceil(services.length / pageSize);
  const [currentPage, setCurrentPage] = useState(0);

  const pagedServices = services.slice(
    currentPage * pageSize,
    currentPage * pageSize + pageSize
  );

  const goToPage = (page: number) => {
    if (page < 0 || page >= totalPages) return;
    setCurrentPage(page);
  };

  // Swipe handler
  const handleDragEnd = (_: MouseEvent | TouchEvent | PointerEvent, info: PanInfo) => {
    const offsetX = info.offset.x;
    const velocityX = info.velocity.x;

    const swipeThreshold = 50;      // px
    const velocityThreshold = 300;  // px/sec

    // Swipe left → next page
    if (offsetX < -swipeThreshold || velocityX < -velocityThreshold) {
      goToPage(currentPage + 1);
    }

    // Swipe right → previous page
    if (offsetX > swipeThreshold || velocityX > velocityThreshold) {
      goToPage(currentPage - 1);
    }
  };

  const onNavigate = () => {
    router.push(Navigation.SERVICES);
  };

  const handelCurrentCategory = (key: ServiceCategoryEnum) => {
    console.log("handelCurrentCategory",key);
    setCurrentCategory(key);
    setCurrentServiceType(key);
    toService(key)
  }

  return (
    <section className="mt-5 rounded-xl  bg-white px-4 pb-3 pt-3 mx-2.5 shadow-lg">
      {/* Header */}
      <div className="mb-1.5 flex items-center justify-between">
        <h2 className="text-sm font-semibold font-color-text">Services</h2>
        <motion.button
          key="767gg"
          type="button"
          aria-label="View all services"
          whileTap={{ scale: 0.94 }}
          transition={{
            type: "spring",
            stiffness: 300,
            damping: 20,
          }}
          className="text-lg text-slate-400"
          onClick={() => onNavigate()}
        >
          <Image
            src="/images/icons/arrow_icon.svg"
            alt="Dropdown"
            width={20}
            height={20}
          />
        </motion.button>
      </div>

      {/* Slider Row with Finger Swipe */}
      <div className="pt-2 overflow-hidden">
        <AnimatePresence mode="wait" initial={false}>
          <motion.div
            key={currentPage}
            className="flex justify-between gap-2"
            initial={{ x: 50, opacity: 0 }}
            animate={{ x: 0, opacity: 1 }}
            exit={{ x: -50, opacity: 0 }}
            transition={{ duration: 0.25, ease: "easeOut" }}
            drag="x"
            dragConstraints={{ left: 0, right: 0 }}
            dragElastic={0.2}
            onDragEnd={handleDragEnd}
          >
            {pagedServices.map((s) => (
              <motion.button
                key={s.label}
                type="button"
                whileTap={{ scale: 0.94 }}
                transition={{
                  type: "spring",
                  stiffness: 300,
                  damping: 20,
                }}
                className="flex flex-1 flex-col items-center"
                onClick={() => handelCurrentCategory(s.key)}
              >
                <div
                  className={`mb-1 flex h-10 w-10 items-center justify-center
                  ${s.key === currentCategory
                      ? "bg-red-600"
                      : "bg-[#F0F6FF]"
                    }
                `}
                >
                  <Image
                    src={`${s.key === currentCategory
                      ? s.activeIcon
                      : s.icon
                      }`}
                    alt={s.label}
                    width={32}
                    height={32}
                    className="h-6 w-6 object-contain"
                  />
                </div>
                <span className="text-xs font-color-text">{s.label}</span>
              </motion.button>
            ))}
          </motion.div>
        </AnimatePresence>
      </div>
    </section>
  );
}




